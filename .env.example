# ── Environment ──
# Copy this file to envs/.env.dev (or .env.qa / .env.prd) and fill in secrets.
# The active env is selected by exporting ENV=<dev|qa|prd> or by sourcing the
# corresponding envs/.env.<env> file before running pipeline commands.
ENV=dev
LOG_LEVEL=DEBUG

# ── Kafka ──
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ── Databricks ──
# Leave host/token/http_path empty to fall back to bronze_writer's local-delta mode.
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_HTTP_PATH=
DATABRICKS_CATALOG=energy_catalog_dev
DATABRICKS_SCHEMA_BRONZE=bronze
DATABRICKS_SCHEMA_SILVER=silver
DATABRICKS_SCHEMA_GOLD=gold

# ── Pipeline ──
DATASET=chile
SEEDS_DIR=transform/seeds
BATCH_SIZE=500

# ── DQ thresholds ──
DQ_NULL_PCT_MAX=5.0
DQ_DUPLICATE_PCT_MAX=1.0
DQ_FRESHNESS_HOURS_MAX=168
DQ_FAIL_ON_WARN=false
